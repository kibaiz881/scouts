{% extends 'component/baseadmin.html.twig' %}

{% block title %}Helder Camara posts list
{% endblock %}

{% block body %}

	{% include 'component/headeradmin.html.twig' %}
	{% include 'component/sidebaradmin.html.twig' %}

	<main
		class="main" id="main" role="main">
		<!-- Page Header -->
		<div class="page-header">
			<div class="page-title">
				<h1>Publication</h1>
				<p>Manage and track all your publication in one place</p>
			</div>
			<div class="page-actions">
				<button class="btn-secondary">
					<i class="bi bi-filter"></i>
					Filter
				</button>
				<a href="{{path('app_admin_post_newpostadmin')}}" class="btn-primary">
					<i class="bi bi-plus"></i>
					New Task
				</a>
			</div>
		</div>

		<!-- Tasks Header -->
		<div class="task-page tasks-header">
			<div class="filter-controls">
				<div class="view-toggle">
					<button class="view-btn active" id="listViewBtn">
						<i class="bi bi-list"></i>
						List
					</button>
					<button class="view-btn" id="gridViewBtn">
						<i class="bi bi-grid-3x3-gap"></i>
						Grid
					</button>
				</div>
			</div>
			<div class="search-box">
				<i class="bi bi-search"></i>
				<input type="text" id="searchInput" placeholder="Search tasks...">
			</div>
		</div>

		<!-- Empty State (Hidden by default) -->
		<div class="empty-state" id="emptyState" style="display: none;">
			<i class="bi bi-check2-square"></i>
			<h3>No tasks found</h3>
			<p>Try adjusting your search or filter to find what you're looking for.</p>
		</div>

		<!-- Tasks List View -->
		<div class="tasks-list-view" id="listView">
			<div class="tasks-table-container">
				<div class="tasks-table-header">
					<h3 class="section-title mb-0">All Tasks</h3>
					<div class="d-flex align-items-center gap-2">
						<span class="text-muted">Showing 12 of 45 tasks</span>
						<select class="form-select" style="width: auto; background: var(--card); color: var(--text); border-color: var(--border);">
							<option>Sort by: Due Date</option>
							<option>Sort by: Priority</option>
							<option>Sort by: Status</option>
							<option>Sort by: Assignee</option>
						</select>
					</div>
				</div>
				<table class="tasks-table">
					<thead>
						<tr>
							<th class="task-checkbox-cell"></th>
							<th>Task</th>
							<th>Assignee</th>
							<th>Priority</th>
							<th>Status</th>
							<th>Due Date</th>
							<th>Actions</th>
						</tr>
					</thead>
					<tbody
						id="tasksTableBody">
						<!-- Task 1 -->
						{% for post in posts %}
							<tr class="task-row" data-status="in-progress" data-priority="high">
								<td class="task-checkbox-cell">
									<div class="task-checkbox">
										<i class="bi bi-check"></i>
									</div>
								</td>
								<td class="task-title-cell">
									<div class="task-title">{{post.title}}</div>
									<div class="task-project">
										<i class="bi bi-kanban"></i>
										<a href="project-details.html">{{post.content}}</a>
									</div>
								</td>
								<td>
									<div class="task-assignee">
										<div class="assignee-avatar" style="background: #00B7FF; color: white;">{{post.user.username|first|upper}}</div>
										<span>{{post.user.username}}</span>
									</div>
								</td>
								<td>
									<span class="task-priority priority-high">High</span>
								</td>
								<td>
									<span class="task-status status-in-progress">In Progress</span>
								</td>
								<td class="task-due-date">
									<span class="due-date">Dec 5, 2023</span>
									<span class="days-left">2 days left</span>
								</td>
								<td>
									<div class="task-actions">
										<a href="task-create.html" class="task-action-btn" title="Edit">
											<i class="bi bi-pencil"></i>
										</a>
										<a href="task-details.html" class="task-action-btn" title="View">
											<i class="bi bi-eye"></i>
										</a>
										<button class="task-action-btn" title="Delete">
											<i class="bi bi-trash"></i>
										</button>
									</div>
								</td>
							</tr>
						{% endfor %}

					</tbody>
				</table>
			</div>
		</div>

		<!-- Tasks Grid View -->
		<div class="tasks-grid-view" id="gridView">
			<div
				class="tasks-grid" id="tasksGrid">
				<!-- Task Card 1 -->
				{% for post in posts %}
					<div class="task-card" data-status="in-progress" data-priority="high">
						<div class="task-card-header">
							<div class="task-card-checkbox">
								<i class="bi bi-check"></i>
							</div>

							<div class="task-card-title">
								<h4>{{ post.title }}</h4>
								<div class="task-card-project">
									<i class="bi bi-kanban"></i>
									<a href="#">{{ post.user.fonctionScout }}</a>
								</div>
							</div>
						</div>
						{% if post.postPictureName %}
							<img src="{{ post.postPictureName ? asset('images/posts/' ~ post.postPictureName) : asset('images/posts/75hc.jpg') }}" class="img-fluid" style="width:100%; height:200px; object-fit:cover; border-radius:10px 10px 0 0;">
						{% endif %}
						<p class="task-card-description">
							{{ post.content }}
						</p>

						<div class="task-card-meta">
							<div class="meta-item">
								<i class="bi bi-calendar"></i>
								<span>{{ post.postedAt | date('d/m/Y') }}</span>
							</div>

							<div class="meta-item">
								<span class="task-priority priority-high">High</span>
							</div>
						</div>

						<div class="task-card-footer">
							<div class="task-card-assignee">

								<div class="card-assignee-avatar">
									<img src="{{ asset('images/profiles/' ~ post.user.profilePictureName) }}" alt="Photo de profil de {{ post.user.username }}" width="40" height="40" style="border-radius:50%; object-fit:cover;">
								</div>

								<div>
									<div class="assignee-name">
										{{ post.user.username | slice(0, 15) | upper }}
									</div>
									<div class="task-status status-in-progress">
										<span id="status-{{ post.id }}" class="badge
											{% if post.isPublished %}
												bg-success
											{% else %}
												bg-warning
											{% endif %}
										">
											{% if post.isPublished %}
												Published
											{% else %}
												Pending
											{% endif %}
										</span>
									</div>
								</div>

							</div>

							<div class="task-card-actions">
								<a href="#" class="card-action-btn" title="Edit">
									<i class="bi bi-pencil"></i>
								</a>
								<a href="#" class="card-action-btn" title="View">
									<i class="bi bi-eye"></i>
								</a>
								<a href="#" class="card-action-btn text-success" onclick="approvePost({{ post.id }})" title="Approve">
									<i class="bi bi-check2-circle"></i>
								</a>

								<a href="#" class="card-action-btn text-danger" onclick="rejectPost({{ post.id }})" title="Reject">
									<i class="bi bi-x-circle"></i>
								</a>

							</div>

						</div>
					</div>

				{% endfor %}
			</div>
		</div>
	</main>

	{% include 'component/footeradmin.html.twig' %}

	{% block javascripts %}
		 <script>
									function approvePost(postId){
						
						    fetch("/admin/post/approve/" + postId,{
						        method:"POST",
						        headers:{
						            "X-Requested-With":"XMLHttpRequest"
						        }
						    })
						    .then(res => res.json())
						    .then(data =>{
						
						        if(data.success){
						
						            let badge = document.getElementById("status-"+postId);
						            badge.classList.remove("bg-warning");
						            badge.classList.add("bg-success");
						            badge.innerText = "Published";
									        Toastify({
												text: "Post approuvé avec succès",
												duration: 3000,
												gravity: "top",
												position: "right",
												backgroundColor: "#28a745"
											}).showToast();
						        }
						
						    });
						
						}
						
						function rejectPost(postId){
						
						    fetch("/admin/post/reject/" + postId,{
						        method:"POST",
						        headers:{
						            "X-Requested-With":"XMLHttpRequest"
						        }
						    })
						    .then(res => res.json())
						    .then(data =>{
						
						        if(data.success){
						
						            let badge = document.getElementById("status-"+postId);
						            badge.classList.remove("bg-success");
						            badge.classList.add("bg-danger");
						            badge.innerText = "Rejected";
																		        Toastify({
												text: "Post rejeté avec succès",
												duration: 3000,
												gravity: "top",
												position: "right",
												backgroundColor: "#ff4a1d"
											}).showToast();
						        }
						
						    });
						
						}
						
					</script>
	{% endblock %}
{% endblock %}
