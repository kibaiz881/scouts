{% extends 'component/baseadmin.html.twig' %}

{% block title %}
	Sampana - Admin
{% endblock %}

{% block body %}
	{% include 'component/headeradmin.html.twig' %}
	{% include 'component/sidebaradmin.html.twig' %}

	<main
		class="main" id="main" role="main">
		<!-- Page Header -->
		<div class="page-header">
			<div class="page-title">
				<h1>MP Management</h1>
				<p>Manage your mpiandrakitra members</p>
			</div>
			<div class="page-actions">
				<a href="{{ path('app_admin_mpiandrakitra_new') }}" class="btn-primary" id="inviteMemberBtn">
					<i class="bi bi-plus"></i>
					New Mp Member
				</a>
			</div>
		</div>


		<!-- Filters and Search -->
		<div class="tasks-header mb-4">
			<div class="filter-controls">
				<button class="filter-btn active" data-filter="all">All Mp Team</button>
			</div>
			<div class="search-box">
				<i class="bi bi-search"></i>
				<input type="text" id="searchInput" placeholder="Search tasks...">
			</div>
		</div>

		<!-- Team Members Grid -->

		{% set borders = {
			'MP0001': 'border-warning',
			'MP0002': 'border-success',
			'MP0003': 'border-primary',
			'MP0004': 'border-danger'
		} %}

		<div class="team-grid" id="teamGrid">
			{% for mp in mpiandrakitra %}
				<div
					class="member-card border border-3 {{ borders[mp.codeMp]|default('border-secondary') }}" data-department="development" data-status="online">

					<!-- HEADER NORMAL (sans background) -->
					<div class="member-header">

						<div class="card-assignee-avatar">
							<img src="{{ asset('images/mpiandrakitra/' ~ mp.mpiandrakitraPictureName) }}" alt="{{ mp.nomMp }}" class="member-avatar" width="40" height="40" style="border-radius:50%; object-fit:cover;">
						</div>

						<div class="member-info">
							<div class="member-name">{{ mp.nomMp }}</div>
							<div class="member-role">{{ mp.adresseMp }}</div>
                            <div class="member-role">{{ mp.contactMp }}</div>
                            <div class="member-role">{{ mp.emailMp }}</div>
							<div class="member-contact">
								<i class="bi bi-key"></i>
								<span>Code Sampana:
									{{ mp.codeMp }}</span>
							</div>

							{# <div class="member-contact">
								<i class="bi bi-calendar"></i>
								<span>Date de Création:
									{{ mp.createdAt|date('F,Y-m-d') }}</span>
							</div> #}
							<div class="member-contact">
								<i class="bi bi-house"></i>
								<span>Nom Sampana:
									{{ mp.sampana.nomSampana }}</span>
							</div>
						</div>

						<div class="member-status status-online">
							<i class="bi bi-circle-fill"></i>
							Online
						</div>
					</div>

					<!-- METRICS -->
					<div class="metrics-grid">
						<div class="metric-item">
							<div class="metric-value">{{ mp.cinMp }}</div>
							<div class="metric-label">Effectif</div>
						</div>
						<div class="metric-item">
							<div class="metric-value">{{mp.dateEntrescout | date('d/m/Y')}}</div>
							<div class="metric-label">Scout</div>
						</div>
						<div class="metric-item">
							<div class="metric-value">{{mp.veliranoDateMp | date('d-m-y')}}</div>
							<div class="metric-label">Velirano</div>
						</div>
						{# <div class="metric-item">
							<div class="metric-value">{{mp.professionMp}}</div>
							<div class="metric-label">Profession</div>
						</div> #}
					</div>

					<!-- ACTIONS -->
					<div class="member-actions">
						<a href="{{ path('app_admin_mpiandrakitra_edit', {'id': mp.id}) }}" class="action-btn">
							<i class="bi bi-pencil"></i>
							edit
						</a>

						<a href="{{ path('app_admin_mpiandrakitra_view', {'id': mp.id}) }}" class="action-btn">
							<i class="bi bi-eye"></i>
							View
						</a>

						<a href="{{ path('app_admin_mpiandrakitra_delete', {'id': mp.id}) }}" class="action-btn" onclick="return confirm('Are you sure you want to delete this sampana?')">
							<i class="bi bi-trash"></i>
							delete
						</a>
					</div>

				</div>
			{% endfor %}
		</div>

		<!-- Pagination -->
		<nav>
			<ul
				class="pagination justify-content-center">

				{# PREVIOUS #}
				<li class="page-item {{ mpiandrakitra.currentPageNumber == 1 ? 'disabled' : '' }}">
					<a class="page-link" href="{{ path(app.request.attributes.get('_route'), { 'page': mpiandrakitra.currentPageNumber - 1 }) }}">
						<i class="bi bi-chevron-left"></i>
					</a>
				</li>

				{# PAGES #}
				{% for page in 1..mpiandrakitra.pageCount %}
					<li class="page-item {{ page == mpiandrakitra.currentPageNumber ? 'active' : '' }}">
						<a class="page-link" href="{{ path(app.request.attributes.get('_route'), {'page': page}) }}">
							{{ page }}
						</a>
					</li>
				{% endfor %}

				{# NEXT #}
				<li class="page-item {{ mpiandrakitra.currentPageNumber == mpiandrakitra.pageCount ? 'disabled' : '' }}">
					<a class="page-link" href="{{ path(app.request.attributes.get('_route'), { 'page': mpiandrakitra.currentPageNumber + 1 }) }}">
						<i class="bi bi-chevron-right"></i>
					</a>
				</li>

			</ul>
		</nav>


	</main>
	{% include 'component/footeradmin.html.twig' %}
{% endblock %}
