{% extends 'component/baseadmin.html.twig' %}

{% block title %}
	Sampana - Admin - Update
{% endblock %}

{% block body %}
	{% include 'component/headeradmin.html.twig' %}
	{% include 'component/sidebaradmin.html.twig' %}

	<main class="main" id="main" role="main">

		<!-- Page Header -->
		<div class="page-header d-flex justify-content-between align-items-center mb-4">
			<div>
				<h1 class="h3 mb-1">Update Sampana</h1>
				<p class="text-muted mb-0">Fill in the details to update this sampana</p>
			</div>
			<a href="{{ path('app_admin_sampana') }}" class="btn btn-outline-secondary">
				<i class="bi bi-arrow-left"></i> Back to List
			</a>
		</div>

		<!-- Form Card -->
		<div class="card shadow-sm">
			<div class="card-body">

				{{ form_start(form) }}

				<div class="row">

					<div class="col-md-6 mb-3">
						{{ form_label(form.nomSampana) }}
						{{ form_widget(form.nomSampana, {'attr': {'class': 'form-control'}}) }}
						{{ form_errors(form.nomSampana) }}
					</div>

					<div class="col-md-6 mb-3">
						{{ form_label(form.profileSampana) }}
						{{ form_widget(form.profileSampana, {'attr': {'class': 'form-control'}}) }}
						{{ form_errors(form.profileSampana) }}
					</div>

					<div class="col-md-6 mb-3">
						{{ form_label(form.EffectifSampana) }}
						{{ form_widget(form.EffectifSampana, {'attr': {'class': 'form-control'}}) }}
						{{ form_errors(form.EffectifSampana) }}
					</div>

					<div class="col-md-6 mb-3">
						{{ form_label(form.createdAt) }}
						{{ form_widget(form.createdAt, {'attr': {'class': 'form-control'}}) }}
						{{ form_errors(form.createdAt) }}
					</div>

					<div class="col-12 mb-3">
						{{ form_label(form.description) }}
						{{ form_widget(form.description, {'attr': {'class': 'form-control', 'rows': 4}}) }}
						{{ form_errors(form.description) }}
					</div>

					<div class="col-12 mb-3">
						{{ form_label(form.sampanaPictureFile) }}
						{{ form_widget(form.sampanaPictureFile, {'attr': {'class': 'form-control'}}) }}
						{{ form_errors(form.sampanaPictureFile) }}
					</div>

				</div>

				<!-- Buttons aligned LEFT -->
				<div class="d-flex gap-2 mt-3">
					<button type="submit" class="btn btn-primary">
						<i class="bi bi-check-circle"></i> Update
					</button>

					<a href="{{ path('app_admin_sampana') }}" class="btn btn-danger">
						<i class="bi bi-x-circle"></i> Annuler
					</a>
				</div>

				{{ form_end(form) }}

			</div>
		</div>

	</main>

	{% include 'component/footeradmin.html.twig' %}
{% endblock %}
